<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="InfantryBehaviorTree">
  <BehaviorTree ID="InfantryBehaviorTree">
    <ReactiveFallback>
      <ReactiveSequence decision_id="recover_after_respawn" decision_label="复活回补" condition_ref="recover_after_respawn" action_ref="recover_after_respawn">
        <ShouldRecoverAfterRespawnCondition self_state="{self_state}"/>
        <SubTree ID="RecoverAfterRespawnTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="push_base" decision_label="进攻基地" condition_ref="push_base" action_ref="push_base">
        <ShouldPushBaseCondition battle_context="{battle_context}"/>
        <SubTree ID="PushBaseTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="emergency_defend_base" decision_label="紧急回防基地" condition_ref="emergency_defend_base" action_ref="emergency_defend_base">
        <ShouldEmergencyDefendBaseCondition battle_context="{battle_context}"/>
        <SubTree ID="EmergencyDefendBaseTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="opening_supply" decision_label="补给区补给" condition_ref="needs_supply" action_ref="opening_supply">
        <NeedsSupplyCondition self_state="{self_state}" battle_context="{battle_context}"/>
        <SubTree ID="OpeningSupplyTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="emergency_retreat" decision_label="紧急撤退" condition_ref="critical_state" action_ref="emergency_retreat">
        <IsCriticalStateCondition self_state="{self_state}"/>
        <SubTree ID="EmergencyRetreatTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="infantry_opening_highground" decision_label="开局抢高地增益" condition_ref="infantry_opening_highground" action_ref="infantry_opening_highground">
        <ShouldInfantryOpeningHighgroundCondition self_state="{self_state}" game_status="{game_status}" battle_context="{battle_context}"/>
        <SubTree ID="InfantryOpeningHighgroundTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="activate_energy" decision_label="开符" condition_ref="activate_energy" action_ref="activate_energy">
        <ShouldActivateEnergyCondition battle_context="{battle_context}"/>
        <SubTree ID="ActivateEnergyTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="highground_assault" decision_label="占领高地进攻前哨" condition_ref="take_enemy_highground" action_ref="highground_assault">
        <ShouldTakeEnemyHighgroundCondition battle_context="{battle_context}"/>
        <SubTree ID="HighgroundAssaultTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="push_outpost" decision_label="推进前哨站" condition_ref="push_outpost" action_ref="push_outpost">
        <ShouldPushOutpostCondition battle_context="{battle_context}"/>
        <SubTree ID="PushOutpostTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="intercept_enemy_engineer" decision_label="拦截敌工" condition_ref="intercept_enemy_engineer" action_ref="intercept_enemy_engineer">
        <ShouldInterceptEnemyEngineerCondition enemy_tracks="{enemy_tracks}"/>
        <SubTree ID="InterceptEnemyEngineerTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="swarm_attack" decision_label="发现即集火" condition_ref="has_target" action_ref="swarm_attack">
        <HasEnemyTargetCondition enemy_tracks="{enemy_tracks}"/>
        <SubTree ID="SwarmAttackTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="teamfight_push" decision_label="团战推进" condition_ref="teamfight_window" action_ref="teamfight_push">
        <HasTeamfightWindowCondition enemy_tracks="{enemy_tracks}"/>
        <SubTree ID="TeamfightPushTree"/>
      </ReactiveSequence>
      <ReactiveSequence decision_id="cross_terrain" decision_label="地形跨越" condition_ref="cross_terrain" action_ref="cross_terrain">
        <ShouldCrossTerrainCondition battle_context="{battle_context}"/>
        <SubTree ID="CrossTerrainTree"/>
      </ReactiveSequence>
      <SubTree ID="PatrolKeyFacilitiesTree" decision_id="patrol_key_facilities" decision_label="巡关键设施" action_ref="patrol_key_facilities" fallback="true"/>
    </ReactiveFallback>
  </BehaviorTree>
</root>