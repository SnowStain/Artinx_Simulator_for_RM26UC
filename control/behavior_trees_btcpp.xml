        <SubTree ID="HeroMeleeHighgroundTree"
                 self_state="{self_state}"
                 battle_context="{battle_context}"
                 current_location="{current_location}"/>
      </ReactiveSequence>
      <ReactiveSequence>
        <IsHeroRangedPriorityCondition message="{self_state}"/>
        <SubTree ID="HeroRangedHighgroundTree"
                 self_state="{self_state}"
                 battle_context="{battle_context}"
                 enemy_tracks="{enemy_tracks}"
                 current_location="{current_location}"/>
