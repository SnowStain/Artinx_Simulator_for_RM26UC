  <!-- 共享导航子树：保持 Navi2 / BehaviorTree.CPP 风格，带安全方向兜底。 -->
  <BehaviorTree ID="send_goal">
    <ReactiveSequence>
      <Sequence>
        <GetCurrentLocationActionBTNode current_location="{current_location}"/>
        <GetSafeDirectionBTNode topic_name="/global_costmap/costmap"
                                current_location="{current_location}"
                                safe_direction="{safe_direction}"/>
      </Sequence>
      <Inverter>
        <KeepRunningUntilFailure>
          <Inverter>
            <Fallback>
              <ReactiveSequence>
                <SendGoalActionBTNode goal_pose="{goal_pose}"/>
                <GoalReachedActionAs goal_pose="{goal_pose}" current_location="{current_location}"/>
              </ReactiveSequence>
              <Inverter>
                <Sequence>
                  <PubVelBTNode safe_direction="{safe_direction}"/>
                  <Delay delay_msec="500">
                    <GetCurrentLocationActionBTNode current_location="{current_location}"/>
                  </Delay>
                </Sequence>
              </Inverter>
            </Fallback>
          </Inverter>
        </KeepRunningUntilFailure>
      </Inverter>
    </ReactiveSequence>
  </BehaviorTree>
